<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>管理后台 - <%= settings.title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@5.15.4/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --primary: #667eea;
            --primary-dark: #764ba2;
            --sidebar-bg: #2c3e50;
            --sidebar-text: #ecf0f1;
            --content-bg: #f5f7fa;
            --card-bg: #ffffff;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--content-bg);
            display: flex;
            min-height: 100vh;
        }
        
        .sidebar {
            width: 250px;
            background: var(--sidebar-bg);
            color: var(--sidebar-text);
            padding: 20px 0;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
        }
        
        .sidebar-header {
            padding: 0 20px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 20px;
        }
        
        .sidebar-header h2 { font-size: 1.3rem; }
        .sidebar-header p { font-size: 12px; opacity: 0.7; }
        
        .nav-menu { list-style: none; }
        
        .nav-menu li a {
            display: block;
            padding: 12px 20px;
            color: var(--sidebar-text);
            text-decoration: none;
            transition: all 0.3s;
        }
        
        .nav-menu li a:hover,
        .nav-menu li a.active {
            background: rgba(255,255,255,0.1);
            border-left: 3px solid var(--primary);
        }
        
        .nav-menu li a i { margin-right: 10px; width: 20px; }
        
        .main-content {
            margin-left: 250px;
            flex: 1;
            padding: 30px;
        }
        
        .page-header { margin-bottom: 30px; }
        .page-header h1 { font-size: 1.8rem; color: #333; }
        .page-header p { color: #666; margin-top: 5px; }
        
        .card {
            background: var(--card-bg);
            border-radius: 10px;
            padding: 25px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            margin-bottom: 25px;
        }
        
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid #eee;
        }
        
        .card-header h3 { font-size: 1.2rem; color: #333; }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            padding: 25px;
            border-radius: 10px;
            text-align: center;
        }
        
        .stat-card.stat-clickable { cursor: pointer; display: block; text-decoration: none; }
        .stat-card.stat-clickable:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
        
        .stat-card i { font-size: 2rem; margin-bottom: 10px; }
        .stat-card .stat-number { font-size: 2.5rem; font-weight: bold; }
        .stat-card .stat-label { font-size: 14px; opacity: 0.9; }
        
        .data-table { width: 100%; border-collapse: collapse; }
        
        .data-table th,
        .data-table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }
        
        .data-table th {
            background: #f8f9fa;
            font-weight: 600;
            color: #333;
        }
        
        .data-table tr:hover { background: #f8f9fa; }
        
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-block;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
        }

        .btn-primary:hover { transform: translateY(-2px); }

        .btn-danger { background: #e74c3c; color: white; }
        .btn-success { background: #27ae60; color: white; }
        .btn-warning { background: #f39c12; color: white; }
        .btn-info { background: #3498db; color: white; }
        .btn-secondary { background: #7f8c8d; color: white; }

        .btn-sm { padding: 5px 10px; font-size: 12px; }

        /* Alert 样式 */
        .alert {
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .alert-danger { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .alert-warning { background: #fff3cd; color: #856404; border: 1px solid #ffeeba; }
        .alert-info { background: #d1ecf1; color: #0c5460; border: 1px solid #bee5eb; }
        
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 500; color: #333; }
        
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
        }
        
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary);
        }

        /* 两列表单布局 */
        .form-row {
            display: flex;
            gap: 20px;
            margin-bottom: 0;
        }
        .form-col {
            flex: 1;
            min-width: 0;
        }
        .form-col input,
        .form-col select {
            max-width: 300px;
        }
        
        .message {
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        
        .message.success { background: #d4edda; color: #155724; }
        
        /* 链接筛选栏 */
        .filter-bar {
            padding: 14px 16px;
            background: #f8f9fa;
            border-bottom: 1px solid #eee;
        }
        
        .filter-input {
            padding: 7px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 13px;
            min-width: 160px;
        }
        
        .filter-input:focus {
            outline: none;
            border-color: var(--primary);
        }
        
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: normal;
            background: var(--primary);
            color: #fff;
            vertical-align: middle;
            margin-left: 8px;
        }
        
        .cat-tag {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
            background: #e9ecef;
            color: #495057;
            max-width: 140px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .cat-parent { color: #6c757d; font-size: 12px; }
        .status-show { color: #28a745; font-weight: 500; }
        .status-hidden { color: #6c757d; font-weight: 500; }
        .cat-row { cursor: pointer; }
        .cat-row:hover { background: #f8f9fa; }
        .cat-edit-form { margin: 8px 0; }
        .edit-fields { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
        .edit-fields span { display: inline-flex; align-items: center; gap: 2px; }
        .edit-fields label { font-size: 12px; display: flex; align-items: center; gap: 2px; white-space: nowrap; }
        .edit-fields input, .edit-fields select { padding: 3px 5px; border: 1px solid #ddd; border-radius: 3px; font-size: 12px; }
        
        .message.error { background: #f8d7da; color: #721c24; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2><i class="fas fa-bookmark"></i> MyNav</h2>
            <p>管理后台</p>
        </div>
        
        <ul class="nav-menu">
            <li><a href="/admin" class="<%= action === 'dashboard' ? 'active' : '' %>"><i class="fas fa-tachometer-alt"></i> <span>仪表盘</span></a></li>
            <li><a href="/" target="_blank"><i class="fas fa-home"></i> <span>访问首页</span></a></li>
            <li><a href="/admin/settings" class="<%= action === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i> <span>系统设置</span></a></li>
            <li><a href="/admin/category" class="<%= action === 'category' ? 'active' : '' %>"><i class="fas fa-folder"></i> <span>分类管理</span></a></li>
            <li><a href="/admin/link" class="<%= action === 'link' ? 'active' : '' %>"><i class="fas fa-link"></i> <span>链接管理</span></a></li>
            <li><a href="/admin/profile"><i class="fas fa-user-cog"></i> <span>个人设置</span></a></li>
            <li><a href="/admin/change-password"><i class="fas fa-key"></i> <span>修改密码</span></a></li>
            <li><a href="/logout"><i class="fas fa-sign-out-alt"></i> <span>退出登录</span></a></li>
        </ul>
    </aside>
    
    <main class="main-content">
        <% if (action === 'dashboard') { %>
            <div class="page-header">
                <h1><i class="fas fa-tachometer-alt"></i> 仪表盘</h1>
                <p>欢迎回来，管理员</p>
            </div>

            <% if (message) { %>
            <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= message %></div>
            <% } %>
            <% if (error) { %>
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
            <% } %>

            <div class="stats-grid">
                <a href="/admin/category" class="stat-card stat-clickable">
                    <i class="fas fa-folder"></i>
                    <div class="stat-number"><%= stats.categories %></div>
                    <div class="stat-label">分类数量</div>
                </a>
                <a href="/admin/link" class="stat-card stat-clickable">
                    <i class="fas fa-link"></i>
                    <div class="stat-number"><%= stats.links %></div>
                    <div class="stat-label">链接总数</div>
                </a>
                <div class="stat-card">
                    <i class="fas fa-clock"></i>
                    <div class="stat-number"><%= stats.todayLinks %></div>
                    <div class="stat-label">今日新增</div>
                </div>
            </div>
            
        <% } else if (action === 'category') { %>
            <div class="page-header">
                <h1><i class="fas fa-folder"></i> 分类管理</h1>
                <p>管理书签分类</p>
            </div>
            
            <div class="card">
                <div class="card-header"><h3>添加分类</h3></div>
                <form method="POST" action="/admin/category/add">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>分类名称</label>
                            <input type="text" name="name" required placeholder="输入分类名称">
                        </div>
                        <div class="form-group form-col">
                            <label>父分类</label>
                            <select name="fid">
                                <option value="0">作为一级分类</option>
                                <% categories.forEach(function(cat) { %>
                                    <% if (cat.fid === 0) { %>
                                        <option value="<%= cat.id %>">-- <%= cat.name %></option>
                                    <% } %>
                                <% }); %>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>权重 (越大越靠前)</label>
                            <input type="number" name="weight" value="100">
                        </div>
                        <div class="form-group form-col">
                            <label>图标 (FontAwesome)</label>
                            <input type="text" name="font_icon" value="fa-folder" placeholder="例如: fa-star">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">添加分类</button>
                </form>
            </div>
            
            <div class="card">
                <div class="card-header"><h3>分类列表 (点击行编辑)</h3></div>
                <table class="data-table">
                    <thead>
                        <tr><th>ID</th><th>父分类 / 名称</th><th>图标 / 权重</th><th>显示</th><th>操作</th></tr>
                    </thead>
                    <tbody>
                        <% categories.forEach(function(cat) { %>
                            <% 
                                var parentName = '';
                                if (cat.fid > 0) {
                                    categories.forEach(function(p) { if (p.id == cat.fid) parentName = p.name; });
                                }
                            %>
                            <tr class="cat-row" onclick="toggleCatEdit(<%= cat.id %>)">
                                <td><%= cat.id %></td>
                                <td>
                                    <% if (parentName) { %><span class="cat-parent"><%= parentName %></span> / <% } %><%= cat.name %>
                                </td>
                                <td>
                                    <i class="fas <%= cat.font_icon %>"></i> / <%= cat.weight %>
                                </td>
                                <td>
                                    <% if (cat.hidden == 1) { %>
                                        <span class="status-hidden">隐藏</span>
                                    <% } else { %>
                                        <span class="status-show">显示</span>
                                    <% } %>
                                </td>
                                <td onclick="event.stopPropagation()">
                                    <form method="POST" action="/admin/category/toggle" style="display: inline;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="id" value="<%= cat.id %>">
                                        <button type="submit" class="btn btn-sm"><%= cat.hidden == 1 ? '显示' : '隐藏' %></button>
                                    </form>
                                    <form method="POST" action="/admin/category/delete" style="display: inline;" onsubmit="return confirm('确定删除？')">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="id" value="<%= cat.id %>">
                                        <button type="submit" class="btn btn-danger btn-sm">删除</button>
                                    </form>
                                </td>
                            </tr>
                            <!-- 分类编辑行 -->
                            <tr class="cat-edit-row" id="cat-edit-<%= cat.id %>" style="display:none;">
                                <td colspan="5">
                                    <form method="POST" action="/admin/category/update" class="cat-edit-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="id" value="<%= cat.id %>">
                                        <div class="edit-fields">
                                            <span><label>名称: <input type="text" name="name" value="<%= cat.name %>" required style="width:100px;"></label></span>
                                            <span><label>父分类: 
                                                <select name="fid" style="width:100px;">
                                                    <option value="0" <%= cat.fid==0?'selected':'' %>>一级</option>
                                                    <% categories.forEach(function(p) { if (p.fid==0 && p.id!=cat.id) { %>
                                                        <option value="<%= p.id %>" <%= cat.fid==p.id?'selected':'' %>><%= p.name %></option>
                                                    <% }}); %>
                                                </select>
                                            </label></span>
                                            <span><label>图标: <input type="text" name="font_icon" value="<%= cat.font_icon %>" placeholder="fa-folder" style="width:80px;"></label></span>
                                            <span><label>权重: <input type="number" name="weight" value="<%= cat.weight %>" style="width:50px;"></label></span>
                                            <button type="submit" class="btn btn-primary btn-sm">保存</button>
                                            <button type="button" class="btn btn-secondary btn-sm" onclick="toggleCatEdit(<%= cat.id %>)">取消</button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <script>
            function toggleCatEdit(id) {
                var row = document.getElementById('cat-edit-' + id);
                row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
            }
            </script>
            
        <% } else if (action === 'link') { %>
            <div class="page-header">
                <h1><i class="fas fa-link"></i> 链接管理</h1>
                <p>管理书签链接</p>
            </div>
            
            <% if (message) { %>
            <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= message %></div>
            <% } %>
            
            <div class="card">
                <div class="card-header"><h3>添加链接</h3></div>
                <form method="POST" action="/admin/link/add">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>链接标题</label>
                            <input type="text" name="title" required placeholder="输入链接标题">
                        </div>
                        <div class="form-group form-col">
                            <label>链接地址</label>
                            <input type="url" name="url" required placeholder="https://example.com">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>自定义图标 (可选)</label>
                            <input type="text" name="icon" placeholder="图标URL或留空">
                        </div>
                        <div class="form-group form-col">
                            <label>描述</label>
                            <input type="text" name="description" placeholder="简短描述">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>所属分类</label>
                            <select name="fid" required>
                                <% categories.forEach(function(cat) { %>
                                    <option value="<%= cat.id %>"><%= cat.fid === 0 ? '' : '└─ ' %><%= cat.name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="form-group form-col">
                            <label>权重</label>
                            <input type="number" name="weight" value="100">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">添加链接</button>
                </form>
            </div>
            
            <div class="card">
                <div class="card-header">
                    <h3>
                        链接列表
                        <% if (searchQuery || filterFid) { %>
                            <span class="badge">筛选结果: <%= links.length %> 条</span>
                        <% } else { %>
                            <span class="badge">共 <%= stats.links %> 条</span>
                        <% } %>
                    </h3>
                </div>
                <!-- 搜索 & 筛选 -->
                <div class="filter-bar">
                    <form method="GET" action="/admin/link" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
                        <input type="text" name="q" value="<%= searchQuery %>" placeholder="搜索标题或URL…" class="filter-input">
                        <select name="fid" class="filter-input">
                            <option value="">全部分类</option>
                            <% categories.forEach(function(cat) { %>
                                <option value="<%= cat.id %>" <%= (filterFid == cat.id) ? 'selected' : '' %>>
                                    <%= cat.fid === 0 ? '' : '└─ ' %><%= cat.name %>
                                </option>
                            <% }); %>
                        </select>
                        <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search"></i> 搜索</button>
                        <% if (searchQuery || filterFid) { %>
                            <a href="/admin/link" class="btn btn-secondary btn-sm"><i class="fas fa-times"></i> 清除筛选</a>
                        <% } %>
                    </form>
                </div>
                <table class="data-table">
                    <thead>
                        <tr><th>标题</th><th>URL</th><th>分类</th><th>权重</th><th>置顶</th><th>操作</th></tr>
                    </thead>
                    <tbody>
                        <% if (links.length === 0) { %>
                            <tr><td colspan="5" style="text-align:center;color:#999;padding:20px;">暂无链接</td></tr>
                        <% } %>
                        <% links.forEach(function(link) { %>
                            <% 
                                var catName = '未知分类';
                                categories.forEach(function(c) {
                                    if (c.id == link.fid) catName = c.name;
                                });
                            %>
                            <tr class="link-row" onclick="toggleLinkEdit(<%= link.id %>)">
                                <td><%= link.title %></td>
                                <td><a href="<%= link.url %>" target="_blank"><%= link.url.length > 40 ? link.url.substring(0, 40) + '…' : link.url %></a></td>
                                <td><span class="cat-tag"><%= catName %></span></td>
                                <td><%= link.weight %></td>
                                <td onclick="event.stopPropagation()">
                                    <form method="POST" action="/admin/link/toggle-top" style="display: inline;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="id" value="<%= link.id %>">
                                        <button type="submit" class="btn btn-sm <%= link.topping ? 'btn-warning' : 'btn-primary' %>"><%= link.topping ? '取消置顶' : '置顶' %></button>
                                    </form>
                                </td>
                                <td onclick="event.stopPropagation()">
                                    <form method="POST" action="/admin/link/delete" style="display: inline;" onsubmit="return confirm('确定删除？')">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="id" value="<%= link.id %>">
                                        <button type="submit" class="btn btn-danger btn-sm">删除</button>
                                    </form>
                                </td>
                            </tr>
                            <!-- 链接编辑行 -->
                            <tr class="link-edit-row" id="link-edit-<%= link.id %>" style="display:none;">
                                <td colspan="6">
                                    <form method="POST" action="/admin/link/update" class="link-edit-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <input type="hidden" name="id" value="<%= link.id %>">
                                        <div class="edit-fields">
                                            <span><label>标题: <input type="text" name="title" value="<%= link.title %>" required style="width:120px;"></label></span>
                                            <span><label>URL: <input type="url" name="url" value="<%= link.url %>" required style="width:150px;"></label></span>
                                            <span><label>分类: 
                                                <select name="fid" style="width:100px;">
                                                    <% categories.forEach(function(c) { %>
                                                        <option value="<%= c.id %>" <%= link.fid==c.id?'selected':'' %>><%= c.name %></option>
                                                    <% }); %>
                                                </select>
                                            </label></span>
                                            <span><label>权重: <input type="number" name="weight" value="<%= link.weight %>" style="width:50px;"></label></span>
                                            <span><label>描述: <input type="text" name="description" value="<%= link.description || '' %>" style="width:100px;"></label></span>
                                            <span><label>图标: <input type="text" name="icon" value="<%= link.icon || '' %>" style="width:100px;" placeholder="URL或留空"></label></span>
                                            <button type="submit" class="btn btn-primary btn-sm">保存</button>
                                            <button type="button" class="btn btn-secondary btn-sm" onclick="toggleLinkEdit(<%= link.id %>)">取消</button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <script>
            function toggleLinkEdit(id) {
                var row = document.getElementById('link-edit-' + id);
                row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
            }
            </script>
            
        <% } else if (action === 'settings') { %>
            <div class="page-header">
                <h1><i class="fas fa-cog"></i> 系统设置</h1>
                <p>配置网站基本信息</p>
            </div>

            <% if (message) { %>
            <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= message %></div>
            <% } %>
            <% if (error) { %>
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
            <% } %>

            <div class="card">
                <form method="POST" action="/admin/settings" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <h4 style="margin-bottom:15px;color:#444;border-bottom:1px solid #eee;padding-bottom:8px;">基本信息</h4>
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>网站标题</label>
                            <input type="text" name="title" value="<%= settings.title %>">
                        </div>
                        <div class="form-group form-col">
                            <label>副标题</label>
                            <input type="text" name="subtitle" value="<%= settings.subtitle %>">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>网站描述</label>
                            <input type="text" name="description" value="<%= settings.description %>" placeholder="网站简介">
                        </div>
                        <div class="form-group form-col">
                            <label>关键词</label>
                            <input type="text" name="keywords" value="<%= settings.keywords %>" placeholder="多个用逗号分隔">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>每分类显示链接数</label>
                            <input type="number" name="link_num" value="<%= settings.link_num %>">
                        </div>
                        <div class="form-group form-col">
                            <label>默认主题</label>
                            <select name="theme" class="form-control">
                                <option value="1" <%= settings.theme === '1' || !settings.theme ? 'selected' : '' %>>主题1 - WebStack风格</option>
                                <option value="2" <%= settings.theme === '2' ? 'selected' : '' %>>主题2 - 深色居中</option>
                                <option value="3" <%= settings.theme === '3' ? 'selected' : '' %>>主题3 - 卡片风格</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group form-col">
                            <label>搜索模式</label>
                            <select name="auto_search" class="form-control">
                                <option value="1" <%= settings.auto_search === '1' || settings.auto_search === 1 ? 'selected' : '' %>>自动搜索（输入2字符触发）</option>
                                <option value="0" <%= settings.auto_search === '0' || settings.auto_search === 0 || settings.auto_search === '' ? 'selected' : '' %>>手动搜索（按回车）</option>
                            </select>
                        </div>
                        <div class="form-group form-col"></div>
                    </div>

                    <!-- 背景设置 -->
                    <h4 style="margin:20px 0 15px;color:#444;border-bottom:1px solid #eee;padding-bottom:8px;">背景设置</h4>
                    <div class="form-group">
                        <label>背景类型</label>
                        <select name="bg_type" id="bgType" class="form-control" onchange="toggleBgFields()">
                            <option value="none" <%= (!settings.bg_type || settings.bg_type === 'none') ? 'selected' : '' %>>无背景（使用主题默认）</option>
                            <option value="color" <%= settings.bg_type === 'color' ? 'selected' : '' %>>纯色背景</option>
                            <option value="gradient" <%= settings.bg_type === 'gradient' ? 'selected' : '' %>>渐变背景</option>
                            <option value="image" <%= settings.bg_type === 'image' ? 'selected' : '' %>>图片背景（URL）</option>
                            <option value="upload" <%= settings.bg_type === 'upload' ? 'selected' : '' %>>上传背景图片</option>
                        </select>
                    </div>
                    <div class="form-group" id="bgColorGroup" style="display:none">
                        <label>背景颜色</label>
                        <div style="display:flex;align-items:center;gap:10px">
                            <input type="color" id="bgColorPicker" value="<%= settings.bg_color || '#1a1a2e' %>" style="width:50px;height:36px;border:none;cursor:pointer;border-radius:4px">
                            <input type="text" name="bg_color" id="bgColorText" value="<%= settings.bg_color || '#1a1a2e' %>" class="form-control" style="max-width:200px" placeholder="#1a1a2e">
                        </div>
                        <small class="form-text text-muted">支持 HEX (#1a1a2e)、RGB、颜色名称</small>
                    </div>
                    <div class="form-group" id="bgGradientGroup" style="display:none">
                        <label>渐变色</label>
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
                            <input type="color" id="gradStart" value="<%= (settings.bg_gradient || '').split(',')[0] || '#0f0c29' %>" style="width:50px;height:36px;border:none;cursor:pointer;border-radius:4px">
                            <span style="color:#888">→</span>
                            <input type="color" id="gradEnd" value="<%= (settings.bg_gradient || '').split(',')[1] || '#302b63' %>" style="width:50px;height:36px;border:none;cursor:pointer;border-radius:4px">
                        </div>
                        <input type="text" name="bg_gradient" id="bgGradientText" value="<%= settings.bg_gradient || '' %>" class="form-control" placeholder="起始色,结束色 如: #0f0c29,#302b63">
                        <div id="gradientPreview" style="height:40px;border-radius:8px;margin-top:8px;border:1px solid #ddd"></div>
                        <small class="form-text text-muted">格式：起始颜色,结束颜色（逗号分隔）</small>
                    </div>
                    <div class="form-group" id="bgImageGroup" style="display:none">
                        <label>背景图片 URL</label>
                        <input type="text" name="bg_image" value="<%= settings.bg_image || '' %>" class="form-control" placeholder="https://example.com/bg.jpg">
                        <small class="form-text text-muted">输入图片地址，支持 JPG/PNG/WebP/SVG</small>
                        <div id="bgImagePreview" style="margin-top:8px;height:80px;border-radius:8px;border:1px solid #ddd;background-size:cover;background-position:center;overflow:hidden"></div>
                    </div>
                    <div class="form-group" id="bgUploadGroup" style="display:none">
                        <label>上传背景图片</label>
                        <input type="file" name="bg_file" id="bgFileInput" accept="image/*" style="display:none" onchange="previewUpload(this)">
                        <label for="bgFileInput" class="btn btn-secondary" style="cursor:pointer"><i class="fas fa-upload"></i> 选择图片</label>
                        <span id="bgFileName" style="margin-left:10px;color:#888"></span>
                        <div id="bgUploadPreview" style="margin-top:8px;height:80px;border-radius:8px;border:1px solid #ddd;background-size:cover;background-position:center;overflow:hidden"></div>
                        <small class="form-text text-muted">支持 JPG/PNG/WebP，建议分辨率 1920×1080 以上，文件 &lt; 5MB</small>
                    </div>
                    <div class="form-group" id="bgOverlayGroup" style="display:none">
                        <label>遮罩透明度</label>
                        <div style="display:flex;align-items:center;gap:10px">
                            <input type="range" name="bg_overlay" id="bgOverlay" min="0" max="100" value="<%= settings.bg_overlay !== undefined ? settings.bg_overlay : 85 %>" style="flex:1" oninput="document.getElementById('overlayValue').textContent=this.value+'%'">
                            <span id="overlayValue" style="min-width:40px;text-align:right"><%= settings.bg_overlay !== undefined ? settings.bg_overlay : 85 %>%</span>
                        </div>
                        <small class="form-text text-muted">图片/渐变背景上覆盖半透明遮罩，提高文字可读性</small>
                    </div>
                    <div class="form-group">
                        <label>自定义 Header</label>
                        <textarea name="custom_header" rows="5" placeholder="可放置统计代码、自定义CSS样式或JavaScript代码"><%= settings.custom_header || '' %></textarea>
                        <small class="form-text text-muted">插入到页面 &lt;head&gt; 标签内，用于添加统计代码、自定义样式等</small>
                    </div>
                    <button type="submit" class="btn btn-primary">保存设置</button>
                </form>
            </div>

            <div class="card" style="margin-top: 20px;">
                <h3><i class="fas fa-exchange-alt"></i> 书签导入/导出</h3>
                <p>支持浏览器书签格式（HTML）导入导出</p>
                <div style="display: flex; gap: 10px; margin-top: 15px;">
                    <a href="/admin/export" class="btn btn-success"><i class="fas fa-download"></i> 导出书签</a>
                    <form method="POST" action="/admin/import" enctype="multipart/form-data" style="display: inline;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <input type="file" name="bookmarks" accept=".html" style="display: none;" id="importFile" onchange="this.form.submit()">
                            <label for="importFile" class="btn btn-warning"><i class="fas fa-upload"></i> 导入书签</label>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card" style="margin-top: 20px;">
                <h3><i class="fas fa-database"></i> 数据备份/恢复</h3>
                <p>备份包含所有分类、链接、设置和用户数据（JSON格式）</p>
                <div style="display: flex; gap: 10px; margin-top: 15px;">
                    <a href="/admin/backup" class="btn btn-info"><i class="fas fa-download"></i> 下载备份</a>
                    <form method="POST" action="/admin/restore" enctype="multipart/form-data" style="display: inline;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <input type="file" name="backup" accept=".json" style="display: none;" id="restoreFile" onchange="if(confirm('恢复数据将覆盖现有数据，确定要继续吗？')) this.form.submit()">
                            <label for="restoreFile" class="btn btn-secondary"><i class="fas fa-upload"></i> 恢复数据</label>
                        </div>
                    </form>
                </div>
                <div class="alert alert-warning" style="margin-top: 15px;">
                    <i class="fas fa-exclamation-triangle"></i> <strong>注意：</strong>恢复数据会覆盖现有数据，请谨慎操作！
                </div>
            </div>
        <% } %>
    </main>

<script>
// 背景设置字段切换
function toggleBgFields() {
    var type = document.getElementById('bgType').value;
    document.getElementById('bgColorGroup').style.display = type === 'color' ? '' : 'none';
    document.getElementById('bgGradientGroup').style.display = type === 'gradient' ? '' : 'none';
    document.getElementById('bgImageGroup').style.display = type === 'image' ? '' : 'none';
    document.getElementById('bgUploadGroup').style.display = type === 'upload' ? '' : 'none';
    document.getElementById('bgOverlayGroup').style.display = (type === 'image' || type === 'upload' || type === 'gradient') ? '' : 'none';
    updateGradientPreview();
    updateImagePreview();
}

// 颜色选择器联动
document.getElementById('bgColorPicker').addEventListener('input', function() {
    document.getElementById('bgColorText').value = this.value;
});
document.getElementById('bgColorText').addEventListener('input', function() {
    if (/^#[0-9a-f]{6}$/i.test(this.value)) document.getElementById('bgColorPicker').value = this.value;
});

// 渐变预览
function updateGradientPreview() {
    var text = document.getElementById('bgGradientText').value;
    var parts = text.split(',');
    if (parts.length === 2 && parts[0].trim() && parts[1].trim()) {
        document.getElementById('gradientPreview').style.background = 'linear-gradient(135deg,' + parts[0].trim() + ',' + parts[1].trim() + ')';
    }
}
document.getElementById('gradStart').addEventListener('input', function() {
    var end = document.getElementById('gradEnd').value;
    document.getElementById('bgGradientText').value = this.value + ',' + end;
    updateGradientPreview();
});
document.getElementById('gradEnd').addEventListener('input', function() {
    var start = document.getElementById('gradStart').value;
    document.getElementById('bgGradientText').value = start + ',' + this.value;
    updateGradientPreview();
});
document.getElementById('bgGradientText').addEventListener('input', updateGradientPreview);

// 图片URL预览
function updateImagePreview() {
    var url = document.querySelector('[name="bg_image"]').value;
    if (url) {
        document.getElementById('bgImagePreview').style.backgroundImage = 'url(' + url + ')';
    } else {
        document.getElementById('bgImagePreview').style.backgroundImage = 'none';
    }
}
document.querySelector('[name="bg_image"]').addEventListener('input', updateImagePreview);

// 上传预览
function previewUpload(input) {
    if (input.files && input.files[0]) {
        var file = input.files[0];
        document.getElementById('bgFileName').textContent = file.name;
        if (file.size > 5 * 1024 * 1024) {
            alert('文件大小不能超过 5MB');
            input.value = '';
            return;
        }
        var reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('bgUploadPreview').style.backgroundImage = 'url(' + e.target.result + ')';
        };
        reader.readAsDataURL(file);
    }
}

// 初始化
toggleBgFields();
updateGradientPreview();
updateImagePreview();
</script>
</body>
</html>
