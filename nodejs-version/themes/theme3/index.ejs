    <% if (isLoggedIn) { %>
        <a href="/admin" class="float-btn" title="管理后台"><i class="fa fa-cog"></i></a>
    <% } else { %>
        <a href="/login" class="float-btn" title="登录"><i class="fa fa-cog"></i></a>
    <% } %>
    <a href="#top" class="float-btn" title="回到顶部"><i class="fa fa-arrow-up"></i></a>
</div>
</body>
</html>
